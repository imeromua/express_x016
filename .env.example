# Telegram
BOT_TOKEN=your_bot_token_here
GROUP_ID=-100123456789
ADMIN_IDS=123456789,987654321

# Database
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/epicentr_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# VirusTotal (необов'язково — залишити порожнім для вимкнення)
VIRUSTOTAL_API_KEY=

# Broadcast (затримка між повідомленнями, секунд)
BROADCAST_DELAY=0.05

# Onboarding (хвилин на завершення реєстрації)
REGISTRATION_TIMEOUT_MINUTES=30
