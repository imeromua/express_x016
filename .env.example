# ──────────────────────────────────────────
#  Telegram
# ──────────────────────────────────────────
BOT_TOKEN=1234567890:ABCDefghIJKlmnoPQRsTUVwxyz

# ID адмінів через кому (BigInt)
ADMIN_IDS=123456789,987654321

# ID приватної групи (BigInt, зазвичай від'ємний)
GROUP_ID=-1001234567890

# ──────────────────────────────────────────
#  PostgreSQL
# ──────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=express_bot
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=strong_password

# ──────────────────────────────────────────
#  Redis
# ──────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ──────────────────────────────────────────
#  VirusTotal
# ──────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ──────────────────────────────────────────
#  Часовий пояс
# ──────────────────────────────────────────
TIMEZONE=Europe/Kyiv

# ──────────────────────────────────────────
#  Throttling (anti-spam, секунди)
# ──────────────────────────────────────────
SCHEDULE_REQUEST_COOLDOWN=5
BROADCAST_DELAY=0.05

# ──────────────────────────────────────────
#  Реєстрація — таймаут FSM (хвилини)
# ──────────────────────────────────────────
REGISTRATION_TIMEOUT_MINUTES=10
