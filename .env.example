# Telegram
BOT_TOKEN=your_bot_token_here
GROUP_ID=-100123456789
ADMIN_IDS=123456789,987654321

# Database
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/express_x016

# Redis
REDIS_URL=redis://localhost:6379/0

# VirusTotal (необов'язково)
VIRUSTOTAL_API_KEY=

# Broadcast (затримка між повідомленнями, секунд)
BROADCAST_DELAY=0.05

# Onboarding (хвилина на завершення реєстрації, хвилини)
REGISTRATION_TIMEOUT_MINUTES=30

# Timezone (для коректного визначення дати графіка)
TIMEZONE=Europe/Kyiv
